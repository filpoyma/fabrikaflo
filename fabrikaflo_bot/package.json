{
  "name": "fabrikaflo-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "dev": "node --watch src/server.ts",
    "start": "node src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "node --test",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/autoload": "^6.4.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/error": "^4.2.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/type-provider-typebox": "^5.2.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sinclair/typebox": "^0.34.51",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "env-schema": "^7.0.0",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "grammy": "^1.44.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.5",
    "prisma": "^7.8.0",
    "typescript-eslint": "^8.63.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
