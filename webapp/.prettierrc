{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "printWidth": 100,
  "tabWidth": 2,
  "arrowParens": "always",
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "<BUILTIN_MODULES>",
    "<THIRD_PARTY_MODULES>",
    "\\.(css|sass|scss|less)$",
    "",
    "^(?!.*\\.(css|sass|scss|less)$)[./]"
  ],
  "importOrderSafeSideEffects": ["\\.(css|sass|scss|less)$"],
  "importOrderParserPlugins": ["typescript", "jsx"]
}
