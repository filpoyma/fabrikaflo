    "@fastify/sensible": "^6.0.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@fastify/type-provider-typebox": "^5.0.0",
    "@sinclair/typebox": "^0.34.49",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.5.1",
    "env-schema": "^7.0.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "grammy": "^1.44.0",
